<Window x:Class="WinLicApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Licensing &amp; Information Manager"
        Icon="winlic_256.png"
        Height="720" Width="1120" MinHeight="500" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Background="#f8f7fe">
    <Window.Resources>

        <!-- Sidebar action button -->
        <Style x:Key="SideBtn" TargetType="Button">
            <Setter Property="Background" Value="#e8e4f5"/>
            <Setter Property="Foreground" Value="#2d2359"/>
            <Setter Property="BorderBrush" Value="#c9c2e8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#ddd7f0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#cfc9e8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger button -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource SideBtn}">
            <Setter Property="Background" Value="#fef2f2"/>
            <Setter Property="BorderBrush" Value="#fca5a5"/>
            <Setter Property="Foreground" Value="#b91c1c"/>
        </Style>

        <!-- Utility button (clear, etc.) -->
        <Style x:Key="UtilBtn" TargetType="Button" BasedOn="{StaticResource SideBtn}">
            <Setter Property="Background" Value="#f4f2f9"/>
            <Setter Property="BorderBrush" Value="#d4cdf0"/>
            <Setter Property="Foreground" Value="#9c98b5"/>
        </Style>

        <!-- Language toggle — inactive -->
        <Style x:Key="LangBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9c98b5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#2d2359"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Language toggle — active -->
        <Style x:Key="LangBtnActive" TargetType="Button" BasedOn="{StaticResource LangBtn}">
            <Setter Property="Foreground" Value="#7c3aed"/>
        </Style>


        <!-- Tab — active (Edge/Explorer: raised, no bottom border, merges with body) -->
        <Style x:Key="TabBtnActive" TargetType="Button">
            <Setter Property="Background" Value="#f5f3ff"/>
            <Setter Property="Foreground" Value="#4c1d95"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#c4b5fd" BorderThickness="1,1,1,0"
                                CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}"
                                Margin="0,4,2,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab — inactive (flat, sits lower, hover highlight) -->
        <Style x:Key="TabBtnInactive" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7c3aed"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}"
                                Margin="0,6,2,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#ddd7f0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="#ece9fb"
                BorderBrush="#d4cdf0" BorderThickness="0,0,0,1"
                Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: icon + title + admin status -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="winlic_256.png" Width="28" Height="28" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtTitle"
                                       FontFamily="Segoe UI Semibold" FontSize="16"
                                       Foreground="#4c1d95"/>
                            <TextBlock x:Name="TxtAppVersion"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#a78bfa" VerticalAlignment="Bottom"
                                       Margin="0,0,0,1"/>
                        </StackPanel>
                        <TextBlock x:Name="AdminStatusText"
                                   FontFamily="Segoe UI" FontSize="11" Margin="0,3,0,0"
                                   Foreground="#6e6a8a"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: language toggle + About + Elevate -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- EN | VI toggle -->
                    <Border BorderBrush="#c9c2e8" BorderThickness="1" CornerRadius="5"
                            Margin="0,0,8,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnLangEN" Content="EN"
                                    Style="{StaticResource LangBtn}"
                                    Click="BtnLangEN_Click"/>
                            <Rectangle Width="1" Fill="#c9c2e8"/>
                            <Button x:Name="BtnLangVIE" Content="VI"
                                    Style="{StaticResource LangBtnActive}"
                                    Click="BtnLangVIE_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- About -->
                    <Button x:Name="BtnAbout"
                            Style="{StaticResource SideBtn}"
                            HorizontalContentAlignment="Center"
                            Margin="0,0,8,0"
                            Click="BtnAbout_Click"/>

                    <!-- Elevate -->
                    <Button x:Name="BtnElevate"
                            Style="{StaticResource SideBtn}"
                            HorizontalContentAlignment="Center"
                            Background="#f5f0ff" BorderBrush="#a78bfa" Foreground="#7c3aed"
                            Visibility="Collapsed"
                            Click="BtnElevate_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Tab bar (Edge/Explorer style, full width) ── -->
        <Border Grid.Row="1" Background="#ece9fb"
                BorderBrush="#d4cdf0" BorderThickness="0,0,0,1"
                Padding="8,0,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button x:Name="TabWin"
                        Style="{StaticResource TabBtnActive}"
                        Click="TabWin_Click"/>
                <Button x:Name="TabOffice"
                        Style="{StaticResource TabBtnInactive}"
                        Click="TabOffice_Click"/>
            </StackPanel>
        </Border>
        <!-- ── Body: sidebar + log ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#f0edf9"
                    BorderBrush="#d4cdf0" BorderThickness="0,0,1,0">
                <StackPanel>

                    <!-- Windows 10/11 tab content -->
                    <StackPanel x:Name="WinTabContent" Margin="10,10">
                        <Button x:Name="BtnVersionInfo"     Style="{StaticResource SideBtn}"
                                Click="BtnWindowsAudit_Click"/>
                        <Button x:Name="BtnTestKey"         Style="{StaticResource DangerBtn}"
                                Click="BtnTestKey_Click"/>
                        <Button x:Name="BtnRemoveLicense"   Style="{StaticResource DangerBtn}"
                                Click="BtnRemoveLicense_Click"/>
                        <Button x:Name="BtnResetActivation" Style="{StaticResource DangerBtn}"
                                Click="BtnResetActivation_Click"/>
                        <Button x:Name="BtnPiracyCheck"     Style="{StaticResource SideBtn}"
                                Click="BtnPiracyCheck_Click"/>
                        <Button x:Name="BtnChangeChannel"   Style="{StaticResource DangerBtn}"
                                Click="BtnChangeChannel_Click"/>
                        <Button x:Name="BtnKmsSettings"     Style="{StaticResource SideBtn}"
                                Click="BtnKmsSettings_Click"/>
                        <Button x:Name="BtnKmsActivate"     Style="{StaticResource DangerBtn}"
                                Click="BtnKmsActivate_Click"/>
                        <Button x:Name="BtnAuditSettings"   Style="{StaticResource UtilBtn}"
                                Click="BtnAuditSettings_Click"/>

                        <Separator Background="#d4cdf0" Margin="0,16,0,6"/>
                        <CheckBox x:Name="ChkShowFullKey"
                                  Margin="4,0,4,8"
                                  Foreground="#6b7280"
                                  FontFamily="Segoe UI" FontSize="11"
                                  Cursor="Hand"/>
                        <Button x:Name="BtnClear" Style="{StaticResource UtilBtn}"
                                HorizontalContentAlignment="Center"
                                Click="BtnClear_Click"/>
                    </StackPanel>

                    <!-- Office 2019+ tab content -->
                    <!-- Office 2019+ tab content -->
                    <StackPanel x:Name="OfficeTabContent" Visibility="Collapsed"
                                Margin="10,12" HorizontalAlignment="Stretch">
                        <Border Background="#fefce8" BorderBrush="#fde047" BorderThickness="1"
                                CornerRadius="8" Padding="14,12"
                                HorizontalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="&#x1F6A7;"
                                           FontSize="24" HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <TextBlock x:Name="OfficeDevTitle"
                                           FontFamily="Segoe UI Semibold" FontSize="12"
                                           Foreground="#713f12" HorizontalAlignment="Center"
                                           TextWrapping="Wrap" TextAlignment="Center"
                                           MaxWidth="180" Margin="0,0,0,6"/>
                                <TextBlock x:Name="OfficeDevDesc"
                                           FontFamily="Segoe UI" FontSize="10"
                                           Foreground="#92400e" HorizontalAlignment="Center"
                                           TextWrapping="Wrap" TextAlignment="Center"
                                           MaxWidth="180"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Log area: stacks LogBox and KeyEntryPanel in same cell -->
            <Grid Grid.Column="1">
                <!-- Log (RichTextBox) — always visible in background -->
                <RichTextBox x:Name="LogBox"
                             Background="#ffffff" BorderThickness="0"
                             IsReadOnly="True" IsDocumentEnabled="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="12" Padding="18,14">
                    <FlowDocument x:Name="LogDocument"
                                  FontFamily="Cascadia Code, Consolas, Courier New"/>
                </RichTextBox>

                <!-- Key Entry Panel — collapsed until Option 2 activates it -->
                <Border x:Name="KeyEntryPanel"
                        Visibility="Collapsed"
                        Background="#f8f7fe" Opacity="0.97"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="#a78bfa" BorderThickness="1"
                        CornerRadius="10" Padding="36,28">
                    <StackPanel>
                        <!-- Title -->
                        <TextBlock x:Name="KpTitle"
                                   FontFamily="Segoe UI Semibold" FontSize="16"
                                   Foreground="#4c1d95" HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <!-- Pre-arm info block -->
                        <Border Background="#f3f0fe" BorderBrush="#c4b5fd" BorderThickness="1"
                                CornerRadius="6" Padding="16,10" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock x:Name="KpInfo1"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#4c1d95" TextWrapping="Wrap"
                                           MaxWidth="380" HorizontalAlignment="Center"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="KpInfo2"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#5b21b6" TextWrapping="Wrap"
                                           MaxWidth="380" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Overwrite warning block -->
                        <Border Background="#fffbeb" BorderBrush="#fcd34d" BorderThickness="1"
                                CornerRadius="6" Padding="16,10" Margin="0,0,0,16">
                            <TextBlock x:Name="KpWarn"
                                       FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#92400e" TextWrapping="Wrap"
                                       MaxWidth="380" HorizontalAlignment="Center"/>
                        </Border>

                        <!-- 5 segmented blocks + dashes -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,0,0,16">
                            <TextBox x:Name="KBox1" MaxLength="5" Width="60" Height="44"
                                     FontFamily="Cascadia Code, Consolas" FontSize="18"
                                     TextAlignment="Center" CharacterCasing="Upper"
                                     BorderBrush="#a78bfa" BorderThickness="2"
                                     Background="#ffffff" Foreground="#2d2359"
                                     VerticalContentAlignment="Center"
                                     PreviewKeyDown="KeyBox_PreviewKeyDown"
                                     TextChanged="KeyBox_TextChanged" Tag="1"/>
                            <TextBlock Text=" — " VerticalAlignment="Center"
                                       FontFamily="Segoe UI" FontSize="18" Foreground="#a78bfa"/>
                            <TextBox x:Name="KBox2" MaxLength="5" Width="60" Height="44"
                                     FontFamily="Cascadia Code, Consolas" FontSize="18"
                                     TextAlignment="Center" CharacterCasing="Upper"
                                     BorderBrush="#a78bfa" BorderThickness="2"
                                     Background="#ffffff" Foreground="#2d2359"
                                     VerticalContentAlignment="Center"
                                     PreviewKeyDown="KeyBox_PreviewKeyDown"
                                     TextChanged="KeyBox_TextChanged" Tag="2"/>
                            <TextBlock Text=" — " VerticalAlignment="Center"
                                       FontFamily="Segoe UI" FontSize="18" Foreground="#a78bfa"/>
                            <TextBox x:Name="KBox3" MaxLength="5" Width="60" Height="44"
                                     FontFamily="Cascadia Code, Consolas" FontSize="18"
                                     TextAlignment="Center" CharacterCasing="Upper"
                                     BorderBrush="#a78bfa" BorderThickness="2"
                                     Background="#ffffff" Foreground="#2d2359"
                                     VerticalContentAlignment="Center"
                                     PreviewKeyDown="KeyBox_PreviewKeyDown"
                                     TextChanged="KeyBox_TextChanged" Tag="3"/>
                            <TextBlock Text=" — " VerticalAlignment="Center"
                                       FontFamily="Segoe UI" FontSize="18" Foreground="#a78bfa"/>
                            <TextBox x:Name="KBox4" MaxLength="5" Width="60" Height="44"
                                     FontFamily="Cascadia Code, Consolas" FontSize="18"
                                     TextAlignment="Center" CharacterCasing="Upper"
                                     BorderBrush="#a78bfa" BorderThickness="2"
                                     Background="#ffffff" Foreground="#2d2359"
                                     VerticalContentAlignment="Center"
                                     PreviewKeyDown="KeyBox_PreviewKeyDown"
                                     TextChanged="KeyBox_TextChanged" Tag="4"/>
                            <TextBlock Text=" — " VerticalAlignment="Center"
                                       FontFamily="Segoe UI" FontSize="18" Foreground="#a78bfa"/>
                            <TextBox x:Name="KBox5" MaxLength="5" Width="60" Height="44"
                                     FontFamily="Cascadia Code, Consolas" FontSize="18"
                                     TextAlignment="Center" CharacterCasing="Upper"
                                     BorderBrush="#a78bfa" BorderThickness="2"
                                     Background="#ffffff" Foreground="#2d2359"
                                     VerticalContentAlignment="Center"
                                     PreviewKeyDown="KeyBox_PreviewKeyDown"
                                     TextChanged="KeyBox_TextChanged" Tag="5"/>
                        </StackPanel>

                        <!-- "Type OK to confirm" label -->
                        <TextBlock x:Name="KpConfirmLabel"
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="#4c1d95" HorizontalAlignment="Center"
                                   Margin="0,12,0,8"/>

                        <!-- OK input box (centered) -->
                        <TextBox x:Name="KpOkBox"
                                 Width="80" Height="36"
                                 FontFamily="Segoe UI Semibold" FontSize="14"
                                 TextAlignment="Center"
                                 HorizontalAlignment="Center"
                                 BorderBrush="#a78bfa" BorderThickness="2"
                                 Background="#ffffff" Foreground="#4c1d95"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,14"
                                 PreviewKeyDown="KpOkBox_PreviewKeyDown"/>

                        <!-- Hint text -->
                        <TextBlock x:Name="KpHint"
                                   FontFamily="Segoe UI" FontSize="10"
                                   Foreground="#9c98b5" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" MaxWidth="380"
                                   Margin="0,0,0,22"/>

                        <!-- Buttons row -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="BtnKeyCancel" Width="100" Height="32" Margin="0,0,12,0"
                                    Background="#f4f2f9" Foreground="#6e6a8a"
                                    BorderBrush="#c9c2e8" BorderThickness="1"
                                    FontFamily="Segoe UI" FontSize="12" Cursor="Hand"
                                    Click="BtnKeyCancel_Click"/>
                            <Button x:Name="BtnKeyInstall" Width="120" Height="32"
                                    Background="#7c3aed" Foreground="White" BorderThickness="0"
                                    FontFamily="Segoe UI Semibold" FontSize="12" Cursor="Hand"
                                    Click="BtnKeyInstall_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- DLV Extended Info Panel — collapsed until Option 1 triggers it -->
                <Border x:Name="DlvPanel"
                        Visibility="Collapsed"
                        Background="#f5f3ff" Opacity="0.98"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="#7c3aed" BorderThickness="1"
                        CornerRadius="10" Padding="36,28" MinWidth="440">
                    <StackPanel>
                        <!-- Title -->
                        <TextBlock x:Name="DlvTitle"
                                   FontFamily="Segoe UI Semibold" FontSize="16"
                                   Foreground="#4c1d95" HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <!-- Description -->
                        <Border Background="#ede9fe" BorderBrush="#c4b5fd" BorderThickness="1"
                                CornerRadius="6" Padding="16,10" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock x:Name="DlvDesc1"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#4c1d95" TextWrapping="Wrap"
                                           MaxWidth="360" HorizontalAlignment="Center"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="DlvDesc2"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#6d28d9" TextWrapping="Wrap"
                                           MaxWidth="360" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="BtnDlvCancel" Width="100" Height="32" Margin="0,0,12,0"
                                    Background="#ede9fe" Foreground="#5b21b6"
                                    BorderBrush="#c4b5fd" BorderThickness="1"
                                    FontFamily="Segoe UI" FontSize="12" Cursor="Hand"
                                    Click="BtnDlvCancel_Click"/>
                            <Button x:Name="BtnDlvRun" Width="160" Height="32"
                                    Background="#7c3aed" Foreground="White" BorderThickness="0"
                                    FontFamily="Segoe UI Semibold" FontSize="12" Cursor="Hand"
                                    Click="BtnDlvRun_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Remove Activation Confirm Panel — collapsed until Option 3 activates it -->
                <Border x:Name="RemoveConfirmPanel"
                        Visibility="Collapsed"
                        Background="#fff7f7" Opacity="0.98"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="#f87171" BorderThickness="1"
                        CornerRadius="10" Padding="36,28">
                    <StackPanel>
                        <!-- Title -->
                        <TextBlock x:Name="RcpTitle"
                                   FontFamily="Segoe UI Semibold" FontSize="16"
                                   Foreground="#991b1b" HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <!-- Warning block -->
                        <Border Background="#fef2f2" BorderBrush="#fca5a5" BorderThickness="1"
                                CornerRadius="6" Padding="16,10" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock x:Name="RcpWarn1"
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="#7f1d1d" TextWrapping="Wrap"
                                           MaxWidth="360" HorizontalAlignment="Center"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="RcpWarn2"
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="#7f1d1d" TextWrapping="Wrap"
                                           MaxWidth="360" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- "Type OK to confirm" label -->
                        <TextBlock x:Name="RcpConfirmLabel"
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="#991b1b" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <!-- OK input box (centered) -->
                        <TextBox x:Name="RcpOkBox"
                                 Width="80" Height="36"
                                 FontFamily="Segoe UI Semibold" FontSize="14"
                                 TextAlignment="Center"
                                 HorizontalAlignment="Center"
                                 BorderBrush="#f87171" BorderThickness="2"
                                 Background="#ffffff" Foreground="#991b1b"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,18"
                                 PreviewKeyDown="RcpOkBox_PreviewKeyDown"/>

                        <!-- Hint text -->
                        <TextBlock x:Name="RcpHint"
                                   FontFamily="Segoe UI" FontSize="10"
                                   Foreground="#b45309" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" MaxWidth="360"
                                   Margin="0,0,0,22"/>

                        <!-- Buttons row -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="BtnRemoveCancel" Width="100" Height="32" Margin="0,0,12,0"
                                    Background="#fef2f2" Foreground="#7f1d1d"
                                    BorderBrush="#fca5a5" BorderThickness="1"
                                    FontFamily="Segoe UI" FontSize="12" Cursor="Hand"
                                    Click="BtnRemoveCancel_Click"/>
                            <Button x:Name="BtnRemoveConfirm" Width="140" Height="32"
                                    Background="#dc2626" Foreground="White" BorderThickness="0"
                                    FontFamily="Segoe UI Semibold" FontSize="12" Cursor="Hand"
                                    Click="BtnRemoveConfirm_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Rearm Confirm Panel — collapsed until Option 4 activates it -->
                <Border x:Name="RearmPanel"
                        Visibility="Collapsed"
                        Background="#fff7f7" Opacity="0.98"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="#f87171" BorderThickness="1"
                        CornerRadius="10" Padding="36,28">
                    <StackPanel>
                        <!-- Title -->
                        <TextBlock x:Name="RpTitle"
                                   FontFamily="Segoe UI Semibold" FontSize="16"
                                   Foreground="#991b1b" HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>
                        <!-- Warning block -->
                        <Border Background="#fef2f2" BorderBrush="#fca5a5" BorderThickness="1"
                                CornerRadius="6" Padding="16,10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock x:Name="RpWarn1"
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="#7f1d1d" TextWrapping="Wrap"
                                           MaxWidth="360" HorizontalAlignment="Center"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="RpWarn2"
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="#7f1d1d" TextWrapping="Wrap"
                                           MaxWidth="360" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Rearm count badge -->
                        <Border Background="#fef9f0" BorderBrush="#fcd34d" BorderThickness="1"
                                CornerRadius="6" Padding="14,8" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock x:Name="RpCountLabel"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#92400e" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="RpCountValue"
                                           FontFamily="Segoe UI Semibold" FontSize="16"
                                           Foreground="#7c2d12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Type OK label -->
                        <TextBlock x:Name="RpConfirmLabel"
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="#991b1b" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <!-- OK input box -->
                        <TextBox x:Name="RpOkBox"
                                 Width="80" Height="36"
                                 FontFamily="Segoe UI Semibold" FontSize="14"
                                 TextAlignment="Center" HorizontalAlignment="Center"
                                 BorderBrush="#f87171" BorderThickness="2"
                                 Background="#ffffff" Foreground="#991b1b"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,12"/>
                        <!-- Restart checkbox -->
                        <CheckBox x:Name="RpRestartCheck"
                                  HorizontalAlignment="Center"
                                  FontFamily="Segoe UI" FontSize="11"
                                  Foreground="#7f1d1d" Margin="0,0,0,18"
                                  Cursor="Hand"/>
                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="BtnRpCancel" Width="100" Height="32" Margin="0,0,12,0"
                                    Background="#fef2f2" Foreground="#7f1d1d"
                                    BorderBrush="#fca5a5" BorderThickness="1"
                                    FontFamily="Segoe UI" FontSize="12" Cursor="Hand"
                                    Click="BtnRpCancel_Click"/>
                            <Button x:Name="BtnRpConfirm" Width="150" Height="32"
                                    Background="#dc2626" Foreground="White" BorderThickness="0"
                                    FontFamily="Segoe UI Semibold" FontSize="12" Cursor="Hand"
                                    Click="BtnRpConfirm_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- KMS Activation Panel — collapsed until Option 6 activates it -->
                <Border x:Name="KmsPanel"
                        Visibility="Collapsed"
                        Background="#f5f3ff" Opacity="0.98"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="#6d28d9" BorderThickness="1"
                        CornerRadius="10" Padding="36,28">
                    <StackPanel>
                        <!-- Title -->
                        <TextBlock x:Name="KmsPanelTitle"
                                   FontFamily="Segoe UI Semibold" FontSize="16"
                                   Foreground="#4c1d95" HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <!-- Description block -->
                        <Border Background="#ede9fe" BorderBrush="#c4b5fd" BorderThickness="1"
                                CornerRadius="6" Padding="16,10" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock x:Name="KmsDesc1"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#4c1d95" TextWrapping="Wrap"
                                           MaxWidth="440" HorizontalAlignment="Center"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="KmsDesc2"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#5b21b6" TextWrapping="Wrap"
                                           MaxWidth="440" HorizontalAlignment="Center"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="KmsDesc3"
                                           FontFamily="Segoe UI" FontSize="10"
                                           Foreground="#6d28d9" TextWrapping="Wrap"
                                           MaxWidth="440" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Pre-flight step results (6 rows) -->
                        <Border Background="#f8f7fe" BorderBrush="#ddd6fe" BorderThickness="1"
                                CornerRadius="6" Padding="16,10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock x:Name="KmsStep1" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#374151" TextWrapping="Wrap" MaxWidth="440" Margin="0,0,0,3"/>
                                <TextBlock x:Name="KmsStep2" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#374151" TextWrapping="Wrap" MaxWidth="440" Margin="0,0,0,3"/>
                                <TextBlock x:Name="KmsStep3" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#374151" TextWrapping="Wrap" MaxWidth="440" Margin="0,0,0,3"/>
                                <TextBlock x:Name="KmsStep4" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#374151" TextWrapping="Wrap" MaxWidth="440" Margin="0,0,0,3"/>
                                <TextBlock x:Name="KmsStep5" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#374151" TextWrapping="Wrap" MaxWidth="440" Margin="0,0,0,3"/>
                                <TextBlock x:Name="KmsStep6" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#374151" TextWrapping="Wrap" MaxWidth="440"/>
                            </StackPanel>
                        </Border>

                        <!-- GVLK missing: show key + OK confirmation (hidden until needed) -->
                        <StackPanel x:Name="KmsGvlkSection" Visibility="Collapsed" Margin="0,0,0,12">
                            <Border Background="#fffbeb" BorderBrush="#fcd34d" BorderThickness="1"
                                    CornerRadius="6" Padding="14,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock x:Name="KmsGvlkLabel"
                                               FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#92400e" TextWrapping="Wrap"
                                               MaxWidth="440" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="KmsGvlkKey"
                                               FontFamily="Cascadia Code, Consolas" FontSize="13"
                                               Foreground="#0e7490" HorizontalAlignment="Center"
                                               Margin="0,0,0,4"/>
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="KmsGvlkConfirmLabel"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#4c1d95" HorizontalAlignment="Center"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="KmsGvlkOkBox"
                                     Width="80" Height="36"
                                     FontFamily="Segoe UI Semibold" FontSize="14"
                                     TextAlignment="Center" HorizontalAlignment="Center"
                                     BorderBrush="#a78bfa" BorderThickness="2"
                                     Background="#ffffff" Foreground="#4c1d95"
                                     VerticalContentAlignment="Center" Margin="0,0,0,4"/>
                        </StackPanel>

                        <!-- Manual KMS host input (hidden until DNS fails) -->
                        <StackPanel x:Name="KmsManualSection" Visibility="Collapsed" Margin="0,0,0,12">
                            <Border Background="#fff7ed" BorderBrush="#fed7aa" BorderThickness="1"
                                    CornerRadius="6" Padding="14,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock x:Name="KmsManualLabel"
                                               FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#92400e" HorizontalAlignment="Center"
                                               TextWrapping="Wrap" MaxWidth="440" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="KmsManualHint"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="#9c98b5" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <TextBox x:Name="KmsHostBox"
                                     Width="280" Height="32"
                                     FontFamily="Segoe UI" FontSize="13"
                                     TextAlignment="Center" HorizontalAlignment="Center"
                                     BorderBrush="#f97316" BorderThickness="2"
                                     Background="#ffffff" Foreground="#1e1b4b"
                                     VerticalContentAlignment="Center" Margin="0,0,0,4"/>
                        </StackPanel>

                        <!-- Buttons row -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <Button x:Name="BtnKmsCancel" Width="100" Height="32" Margin="0,0,12,0"
                                    Background="#f5f3ff" Foreground="#6e6a8a"
                                    BorderBrush="#c4b5fd" BorderThickness="1"
                                    FontFamily="Segoe UI" FontSize="12" Cursor="Hand"
                                    Click="BtnKmsCancel_Click"/>
                            <Button x:Name="BtnKmsProceed" Width="180" Height="32"
                                    Background="#6d28d9" Foreground="White" BorderThickness="0"
                                    FontFamily="Segoe UI Semibold" FontSize="12" Cursor="Hand"
                                    IsEnabled="False"
                                    Click="BtnKmsProceed_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!-- Change Activation Channel Panel — collapsed until Option 6 activates it -->
                <Border x:Name="ChangeChannelPanel"
                        Visibility="Collapsed"
                        Background="#fdf4ff" Opacity="0.98"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="#a855f7" BorderThickness="1"
                        CornerRadius="10" Padding="36,28">
                    <StackPanel>
                        <TextBlock x:Name="ChPanelTitle"
                                   FontFamily="Segoe UI Semibold" FontSize="16"
                                   Foreground="#6b21a8" HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>
                        <Border Background="#fae8ff" BorderBrush="#e879f9" BorderThickness="1"
                                CornerRadius="6" Padding="16,10" Margin="0,0,0,14">
                            <TextBlock x:Name="ChDesc"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#6b21a8" TextWrapping="Wrap"
                                       MaxWidth="440" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Background="#f3f0fe" BorderBrush="#c4b5fd" BorderThickness="1"
                                CornerRadius="6" Padding="16,10" Margin="0,0,0,16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <TextBlock x:Name="ChLblChannel" FontFamily="Segoe UI" FontSize="11" Foreground="#4c1d95" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="ChValChannel" FontFamily="Segoe UI Semibold" FontSize="11" Foreground="#1e1b4b"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <TextBlock x:Name="ChLblEdition" FontFamily="Segoe UI" FontSize="11" Foreground="#4c1d95" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="ChValEdition" FontFamily="Segoe UI Semibold" FontSize="11" Foreground="#1e1b4b"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="ChLblKey" FontFamily="Segoe UI" FontSize="11" Foreground="#4c1d95" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="ChValKey" FontFamily="Cascadia Code, Consolas" FontSize="11" Foreground="#0e7490"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
                            <Button x:Name="BtnChToKms" Height="32" Padding="14,0" Margin="0,0,10,0"
                                    Background="#6d28d9" Foreground="White" BorderThickness="0"
                                    FontFamily="Segoe UI" FontSize="12" Cursor="Hand"
                                    Click="BtnChToKms_Click"/>
                            <Button x:Name="BtnChToRetail" Height="32" Padding="14,0"
                                    Background="#db2777" Foreground="White" BorderThickness="0"
                                    FontFamily="Segoe UI" FontSize="12" Cursor="Hand"
                                    Click="BtnChToRetail_Click"/>
                        </StackPanel>
                        <StackPanel x:Name="ChGvlkSection" Visibility="Collapsed" Margin="0,0,0,12">
                            <Border Background="#fffbeb" BorderBrush="#fcd34d" BorderThickness="1"
                                    CornerRadius="6" Padding="14,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock x:Name="ChGvlkLabel"
                                               FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#92400e" TextWrapping="Wrap"
                                               MaxWidth="440" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ChGvlkKey"
                                               FontFamily="Cascadia Code, Consolas" FontSize="13"
                                               Foreground="#0e7490" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="ChGvlkConfirmLabel"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#6b21a8" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBox x:Name="ChGvlkOkBox"
                                     Width="80" Height="36"
                                     FontFamily="Segoe UI Semibold" FontSize="14"
                                     TextAlignment="Center" HorizontalAlignment="Center"
                                     BorderBrush="#a855f7" BorderThickness="2"
                                     Background="#ffffff" Foreground="#6b21a8"
                                     VerticalContentAlignment="Center" Margin="0,0,0,4"/>
                        </StackPanel>
                        <StackPanel x:Name="ChRetailSection" Visibility="Collapsed" Margin="0,0,0,12">
                            <Border Background="#fdf2f8" BorderBrush="#f9a8d4" BorderThickness="1"
                                    CornerRadius="6" Padding="16,10">
                                <TextBlock x:Name="ChRetailMsg"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#831843" TextWrapping="Wrap"
                                           MaxWidth="440" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <Button x:Name="BtnChCancel" Width="100" Height="32" Margin="0,0,12,0"
                                    Background="#fdf4ff" Foreground="#9333ea"
                                    BorderBrush="#d8b4fe" BorderThickness="1"
                                    FontFamily="Segoe UI" FontSize="12" Cursor="Hand"
                                    Click="BtnChCancel_Click"/>
                            <Button x:Name="BtnChProceed" Width="160" Height="32"
                                    Background="#7e22ce" Foreground="White" BorderThickness="0"
                                    FontFamily="Segoe UI Semibold" FontSize="12" Cursor="Hand"
                                    IsEnabled="False"
                                    Click="BtnChProceed_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- KMS Settings Panel — collapsed until Option 7 activates it -->
                <Border x:Name="KmsSettingsPanel"
                        Visibility="Collapsed"
                        Background="#f0f9ff" Opacity="0.98"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="#0284c7" BorderThickness="1"
                        CornerRadius="10" Padding="36,28">
                    <StackPanel>
                        <TextBlock x:Name="Ks7PanelTitle"
                                   FontFamily="Segoe UI Semibold" FontSize="16"
                                   Foreground="#0c4a6e" HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>
                        <Border Background="#e0f2fe" BorderBrush="#7dd3fc" BorderThickness="1"
                                CornerRadius="6" Padding="16,10" Margin="0,0,0,14">
                            <TextBlock x:Name="Ks7Desc"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#0c4a6e" TextWrapping="Wrap"
                                       MaxWidth="440" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Background="#f0f9ff" BorderBrush="#bae6fd" BorderThickness="1"
                                CornerRadius="6" Padding="16,10" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock x:Name="Ks7LblRegHost" FontFamily="Segoe UI" FontSize="11" Foreground="#0369a1" Width="190"/>
                                    <TextBlock x:Name="Ks7ValRegHost" FontFamily="Cascadia Code, Consolas" FontSize="11" Foreground="#1e40af"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock x:Name="Ks7LblRegPort" FontFamily="Segoe UI" FontSize="11" Foreground="#0369a1" Width="190"/>
                                    <TextBlock x:Name="Ks7ValRegPort" FontFamily="Cascadia Code, Consolas" FontSize="11" Foreground="#1e40af"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="Ks7LblDlvHost" FontFamily="Segoe UI" FontSize="11" Foreground="#0369a1" Width="190"/>
                                    <TextBlock x:Name="Ks7ValDlvHost" FontFamily="Cascadia Code, Consolas" FontSize="11" Foreground="#1e40af"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="Ks7StatusLabel"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"
                                   MaxWidth="440" Margin="0,0,0,12"/>
                        <StackPanel x:Name="Ks7ClearSection" Visibility="Collapsed" Margin="0,0,0,12">
                            <Border Background="#fef2f2" BorderBrush="#fca5a5" BorderThickness="1"
                                    CornerRadius="6" Padding="14,8" Margin="0,0,0,8">
                                <TextBlock x:Name="Ks7ClearLabel"
                                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#991b1b" TextWrapping="Wrap"
                                           MaxWidth="440" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="Ks7ConfirmLabel"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#991b1b" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBox x:Name="Ks7OkBox"
                                     Width="80" Height="36"
                                     FontFamily="Segoe UI Semibold" FontSize="14"
                                     TextAlignment="Center" HorizontalAlignment="Center"
                                     BorderBrush="#f87171" BorderThickness="2"
                                     Background="#ffffff" Foreground="#991b1b"
                                     VerticalContentAlignment="Center" Margin="0,0,0,10"/>
                            <Button x:Name="BtnKs7Clear" Height="32" Padding="20,0"
                                    Background="#dc2626" Foreground="White" BorderThickness="0"
                                    FontFamily="Segoe UI Semibold" FontSize="12" Cursor="Hand"
                                    HorizontalAlignment="Center"
                                    Click="BtnKs7Clear_Click"/>
                        </StackPanel>
                        <StackPanel x:Name="Ks7SuggestSection" Visibility="Collapsed" Margin="0,0,0,14">
                            <Border Background="#f0fdf4" BorderBrush="#86efac" BorderThickness="1"
                                    CornerRadius="6" Padding="14,10">
                                <StackPanel>
                                    <TextBlock x:Name="Ks7Suggest1" FontFamily="Segoe UI" FontSize="11" Foreground="#166534" TextWrapping="Wrap" MaxWidth="440" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="Ks7Suggest2" FontFamily="Segoe UI" FontSize="11" Foreground="#166534" TextWrapping="Wrap" MaxWidth="440" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="Ks7Suggest3" FontFamily="Segoe UI" FontSize="11" Foreground="#166534" TextWrapping="Wrap" MaxWidth="440"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button x:Name="BtnKs7Close" Width="120" Height="32"
                                Background="#0284c7" Foreground="White" BorderThickness="0"
                                FontFamily="Segoe UI Semibold" FontSize="12" Cursor="Hand"
                                HorizontalAlignment="Center"
                                Click="BtnKs7Close_Click"/>
                    </StackPanel>
                </Border>

            </Grid>

        </Grid>

        <!-- ── Status bar ── -->
        <Border Grid.Row="3" Background="#ece9fb"
                BorderBrush="#d4cdf0" BorderThickness="0,1" Padding="14,5">
            <TextBlock x:Name="StatusBar"
                       FontFamily="Segoe UI" FontSize="11" Foreground="#9c98b5"/>
        </Border>
    </Grid>
</Window>

<Window x:Class="WinLicApp.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="Self"
        Height="640" Width="660"
        MinHeight="520" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        Background="#f8f7fe"
        ResizeMode="CanResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Section GroupBox style -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush"   Value="#d4cdf0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"        Value="0,0,0,12"/>
            <Setter Property="Padding"       Value="10,8"/>
            <Setter Property="FontFamily"    Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Foreground"    Value="#4c1d95"/>
        </Style>

        <!-- Defaults list box (read-only) -->
        <Style x:Key="DefaultsList" TargetType="TextBox">
            <Setter Property="Background"     Value="#ece9fb"/>
            <Setter Property="BorderBrush"    Value="#c9c2e8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="IsReadOnly"     Value="True"/>
            <Setter Property="Foreground"     Value="#6e6a8a"/>
            <Setter Property="FontFamily"     Value="Cascadia Code, Consolas, Courier New"/>
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="Padding"        Value="6,4"/>
            <Setter Property="TextWrapping"   Value="Wrap"/>
            <Setter Property="AcceptsReturn"  Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- User editable text box -->
        <Style x:Key="UserInput" TargetType="TextBox">
            <Setter Property="Background"     Value="#ffffff"/>
            <Setter Property="BorderBrush"    Value="#a78bfa"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"     Value="#1e1b4b"/>
            <Setter Property="FontFamily"     Value="Cascadia Code, Consolas, Courier New"/>
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="Padding"        Value="6,4"/>
            <Setter Property="TextWrapping"   Value="Wrap"/>
            <Setter Property="AcceptsReturn"  Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="#ece9fb"
                BorderBrush="#d4cdf0" BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel>
                <TextBlock x:Name="TxtDialogTitle"
                           FontFamily="Segoe UI Semibold" FontSize="15"
                           Foreground="#4c1d95"/>
                <TextBlock x:Name="TxtDialogDesc"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="#9c98b5" TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Body: scrollable sections ── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,14">
            <StackPanel>

                <!-- KMS Ports -->
                <GroupBox x:Name="GbPorts">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="TxtDefaultsLabel0" Style="{StaticResource {x:Type TextBlock}}"
                                       FontFamily="Segoe UI" FontSize="10" Foreground="#9c98b5"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtDefaultPorts" Style="{StaticResource DefaultsList}"
                                     Height="52" IsReadOnly="True"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="TxtCustomLabel0"
                                       FontFamily="Segoe UI" FontSize="10" Foreground="#7c3aed"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtExtraPorts" Style="{StaticResource UserInput}" Height="52"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Services -->
                <GroupBox x:Name="GbServices">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="TxtDefaultsLabel1"
                                       FontFamily="Segoe UI" FontSize="10" Foreground="#9c98b5"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtDefaultServices" Style="{StaticResource DefaultsList}"
                                     Height="90" IsReadOnly="True"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="TxtCustomLabel1"
                                       FontFamily="Segoe UI" FontSize="10" Foreground="#7c3aed"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtExtraServices" Style="{StaticResource UserInput}" Height="90"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Task Keywords -->
                <GroupBox x:Name="GbTasks">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="TxtDefaultsLabel2"
                                       FontFamily="Segoe UI" FontSize="10" Foreground="#9c98b5"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtDefaultTasks" Style="{StaticResource DefaultsList}"
                                     Height="80" IsReadOnly="True"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="TxtCustomLabel2"
                                       FontFamily="Segoe UI" FontSize="10" Foreground="#7c3aed"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtExtraTasks" Style="{StaticResource UserInput}" Height="80"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Processes -->
                <GroupBox x:Name="GbProcs">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="TxtDefaultsLabel3"
                                       FontFamily="Segoe UI" FontSize="10" Foreground="#9c98b5"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtDefaultProcs" Style="{StaticResource DefaultsList}"
                                     Height="90" IsReadOnly="True"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="TxtCustomLabel3"
                                       FontFamily="Segoe UI" FontSize="10" Foreground="#7c3aed"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtExtraProcs" Style="{StaticResource UserInput}" Height="90"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Custom File/Folder Paths (no built-in column — paths are computed from env vars) -->
                <GroupBox x:Name="GbFiles">
                    <StackPanel>
                        <TextBlock x:Name="TxtFilesNote"
                                   FontFamily="Segoe UI" FontSize="10" Foreground="#9c98b5"
                                   TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtExtraFiles" Style="{StaticResource UserInput}" Height="70"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Footer ── -->
        <Border Grid.Row="2" Background="#ece9fb"
                BorderBrush="#d4cdf0" BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid>
                <TextBlock x:Name="TxtSaveNote"
                           FontFamily="Segoe UI" FontSize="10"
                           Foreground="#9c98b5" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnUpdateDefaults" Width="160" Height="30" Margin="0,0,8,0"
                            Background="#1a1730" Foreground="#a78bfa"
                            BorderBrush="#7c3aed" BorderThickness="1"
                            FontFamily="Segoe UI" FontSize="11" Cursor="Hand"
                            Click="BtnUpdateDefaults_Click"/>
                    <Button x:Name="BtnCancel" Width="90" Height="30" Margin="0,0,8,0"
                            Background="#f4f2f9" Foreground="#6e6a8a"
                            BorderBrush="#c9c2e8" BorderThickness="1"
                            FontFamily="Segoe UI" FontSize="12" Cursor="Hand"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="BtnSave" Width="90" Height="30"
                            Background="#7c3aed" Foreground="White" BorderThickness="0"
                            FontFamily="Segoe UI Semibold" FontSize="12" Cursor="Hand"
                            Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

<Window x:Class="WinLicApp.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Icon="winlic_256.png"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#f8f7fe">
    <StackPanel Margin="36,28,36,28">

        <Image Source="winlic_256.png" Width="56" Height="56"
               HorizontalAlignment="Center" Margin="0,0,0,12"
               RenderOptions.BitmapScalingMode="HighQuality"/>
        <TextBlock Text="WinLic Manager" HorizontalAlignment="Center"
                   FontFamily="Segoe UI Semibold" FontSize="22" Foreground="#4c1d95"/>
        <TextBlock x:Name="TxtVersion" HorizontalAlignment="Center"
                   FontFamily="Segoe UI" FontSize="12" Foreground="#9c98b5" Margin="0,4,0,0"/>

        <Separator Background="#d4cdf0" Margin="0,20,0,20"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TxtLblAuthor" Grid.Column="0"
                       FontFamily="Segoe UI" FontSize="13" Foreground="#9c98b5"/>
            <TextBlock Grid.Column="1" Text="Arden Nguyen Duc Huy"
                       FontFamily="Segoe UI Semibold" FontSize="13" Foreground="#2d2359"/>
        </Grid>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TxtLblGitHub" Grid.Column="0"
                       FontFamily="Segoe UI" FontSize="13" Foreground="#9c98b5"/>
            <TextBlock Grid.Column="1" FontFamily="Segoe UI" FontSize="13">
                <Hyperlink NavigateUri="https://github.com/ardennguyen"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="#7c3aed">github.com/ardennguyen</Hyperlink>
            </TextBlock>
        </Grid>

        <Grid Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TxtLblRepo" Grid.Column="0"
                       FontFamily="Segoe UI" FontSize="13" Foreground="#9c98b5"/>
            <TextBlock Grid.Column="1" FontFamily="Segoe UI" FontSize="13">
                <Hyperlink NavigateUri="https://github.com/ardennguyen/WinLic"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="#7c3aed">github.com/ardennguyen/WinLic</Hyperlink>
            </TextBlock>
        </Grid>

        <Separator Background="#d4cdf0" Margin="0,20,0,20"/>

        <TextBlock x:Name="TxtDesc" TextWrapping="Wrap" TextAlignment="Center"
                   FontFamily="Segoe UI" FontSize="12" Foreground="#9c98b5"
                   Margin="0,0,0,22" LineHeight="20"/>

        <Button x:Name="BtnClose" Width="110" HorizontalAlignment="Center"
                Click="BtnClose_Click"
                Background="#e8e4f5" Foreground="#2d2359"
                BorderBrush="#c9c2e8" BorderThickness="1"
                Padding="14,8" FontFamily="Segoe UI" FontSize="12"
                Cursor="Hand"/>
    </StackPanel>
</Window>

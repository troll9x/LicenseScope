<Window x:Class="WinLicApp.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="winlic_256.png"
        Title="Input" SizeToContent="WidthAndHeight" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#f8f7fe">
    <StackPanel Margin="24,20">
        <TextBlock x:Name="PromptText" Text="" TextWrapping="Wrap"
                   Foreground="#2d2359" FontFamily="Segoe UI" FontSize="13"
                   Margin="0,0,0,12"/>
        <TextBox x:Name="InputBox"
                 FontFamily="Cascadia Code, Consolas" FontSize="13"
                 Background="#ffffff" Foreground="#2d2359"
                 CaretBrush="#7c3aed"
                 BorderBrush="#c9c2e8" BorderThickness="1"
                 Padding="10,7" Margin="0,0,0,16"
                 KeyDown="InputBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Width="90" Margin="0,0,8,0"
                    Click="OkButton_Click"
                    Background="#7c3aed" Foreground="#ffffff"
                    BorderBrush="#6d28d9" BorderThickness="1"
                    Padding="8,7" FontFamily="Segoe UI" FontSize="12"
                    Cursor="Hand"/>
            <Button x:Name="CancelButton" Width="90"
                    Click="CancelButton_Click"
                    Background="#e8e4f5" Foreground="#4c4c70"
                    BorderBrush="#c9c2e8" BorderThickness="1"
                    Padding="8,7" FontFamily="Segoe UI" FontSize="12"
                    Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>

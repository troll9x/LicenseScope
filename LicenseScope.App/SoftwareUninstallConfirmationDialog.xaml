<Window x:Class="LicenseScope.App.SoftwareUninstallConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xác nhận gỡ phần mềm" Width="560" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#fffaf8">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Cảnh báo: thao tác này sẽ thay đổi hệ thống"
                   FontFamily="Segoe UI Semibold" FontSize="18" Foreground="#b91c1c"/>
        <TextBlock Grid.Row="1" Margin="0,12,0,0" TextWrapping="Wrap">
            <Run Text="Kết quả quét: "/><Run x:Name="ScannedProductText" FontWeight="SemiBold"/>
            <LineBreak/>
            <Run Text="Gói Windows sẽ gỡ: "/><Run x:Name="RegisteredProductText" FontWeight="SemiBold"/>
        </TextBlock>
        <TextBlock Grid.Row="2" Margin="0,12,0,0" Foreground="#7c2d12" TextWrapping="Wrap"
                   Text="Gỡ cài đặt có thể xóa chương trình và làm mất dữ liệu hoặc thiết lập cục bộ. License Scope chỉ mở trình gỡ chính thức đã đăng ký; hãy kiểm tra lại tên gói trước khi tiếp tục."/>
        <StackPanel Grid.Row="3" Margin="0,16,0,0">
            <TextBlock Text="Nhập GO PHAN MEM để xác nhận:"/>
            <TextBox x:Name="ConfirmationTextBox" Height="30" Margin="0,6,0,0"
                     TextChanged="ConfirmationTextBox_TextChanged"/>
        </StackPanel>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Hủy" Width="90" Height="34" Click="Cancel_Click"/>
            <Button x:Name="ConfirmButton" Content="Mở trình gỡ" Width="120" Height="34"
                    Margin="8,0,0,0" IsEnabled="False" Click="Confirm_Click"
                    Background="#b91c1c" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
